# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ─── Frontend (comma-separated list for multi-origin support) ──────────────────
# Production example: FRONTEND_URL=https://yourgame.com,https://www.yourgame.com
FRONTEND_URL=http://localhost:8080

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT Signing Secret ─────────────────────────────────────────────────────────
# REQUIRED in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# The app will refuse to start in production if this is not set.
JWT_SECRET=CHANGE_ME_GENERATE_A_64_CHAR_HEX_SECRET

# ─── Game Timers (seconds unless noted) ────────────────────────────────────────
# How long each gallery canvas is shown during voting (seconds)
VOTING_SECONDS_PER_CANVAS=120
# How long to display gallery/round-results transitions
GALLERY_SECONDS=10
ROUND_RESULTS_SECONDS=10

# ─── Host Migration ─────────────────────────────────────────────────────────────
# Grace period in milliseconds before host role migrates after a disconnect
HOST_MIGRATION_GRACE_MS=30000
